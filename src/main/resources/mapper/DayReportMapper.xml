<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.pmp.hrsrc.mapper.DayReportMapper">

    <select id="selectAll" parameterType="int" resultType="com.pmp.hrsrc.entity.DayReport">
        select * from t_dayreport where pid =#{pid} order by id desc  limit 200;
    </select>
    <insert id="insertDayReport" parameterType="com.pmp.hrsrc.entity.DayReport">
        insert into t_dayreport(id,uid,pid,sdate,scontext,uname) values(#{id},#{uid},#{pid},#{sdate},#{scontext},#{uname})
    </insert>
    <select id="findMaxId" resultType="int">
        select ifnull(max(id),0)+1 from t_dayreport ;
    </select>
    <select id="selectById" resultType="com.pmp.hrsrc.entity.DayReport">
        select * from t_dayreport where id =#{id}
    </select>
    <update id="updateDayReport" parameterType="com.pmp.hrsrc.entity.DayReport">
        update t_dayreport set scontext =#{scontext},sdate=#{sdate}  where id =#{id}
    </update>
    <delete id="deleteDayReport" parameterType="int">
        delete from t_dayreport where id=#{id}
    </delete>
</mapper>