<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.pmp.hrsrc.mapper.PlanMapper">

    <select id="selectAll" parameterType="int" resultType="com.pmp.hrsrc.entity.Plan">
        select * from t_plan where pid=#{id} order by id desc ;
    </select>
    <select id="selectAllDAO" parameterType="int" resultType="com.pmp.hrsrc.entity.PlanDAO">
        select id ,pid ,vid ,(select pname from t_pro where t_pro.id = t2.pid) pname,(select vers from t_version where t_version.id = t2.vid) vers ,ptext ,sdate,edate from t_plan t2 where t2.pid=#{id}
    </select>
    <insert id="insertPlan" parameterType="com.pmp.hrsrc.entity.Plan">
        insert into t_plan(id,pid,vid,ptext,sdate,edate) values(#{id},#{pid},#{vid},#{ptext},#{sdate},#{edate})
    </insert>
    <select id="findMaxId" resultType="int">
        select ifnull(max(id),0)+1 from t_plan ;
    </select>
    <select id="selectById" resultType="com.pmp.hrsrc.entity.Plan">
        select * from t_plan where id =#{id}
    </select>
    <update id="updatePlan" parameterType="com.pmp.hrsrc.entity.Plan">
        update t_plan set pid =#{pid} ,vid =#{vid} ,ptext=#{ptext},sdate=#{sdate},edate=#{edate} where id =#{id}
    </update>
    <delete id="deletePlan" parameterType="int">
        delete from t_plan where id=#{id}
    </delete>
    <select id="selectPlanDetail" parameterType="int" resultType="com.pmp.hrsrc.entity.PlanDetail">
        select * from t_plan_detail where vid = #{id}
    </select>
    <update id="updatePlanDetail" parameterType="com.pmp.hrsrc.entity.PlanDetail">
        update t_plan_detail set sdate =#{sdate},edate =#{edate} where id = #{id}
    </update>
    <delete id="deletePlanDetail" parameterType="int">
        delete from t_plan_detail  where id =#{id}
    </delete>
</mapper>