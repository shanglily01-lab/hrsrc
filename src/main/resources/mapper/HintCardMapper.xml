<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.pmp.hrsrc.mapper.HintCardMapper">

    <select id="selectAll" resultType="com.pmp.hrsrc.entity.HintCard">
        select * from t_hintcard order by id desc limit 200;
    </select>
    <insert id="insertHintCard" parameterType="com.pmp.hrsrc.entity.HintCard">
        insert into t_hintcard(id,ampm,uid,uname,hinttime) values(#{id},#{ampm},#{uid},#{uname},now())
    </insert>
    <select id="findMaxId" resultType="int">
        SELECT ifnull(max(id),0)+1 FROM t_hintcard;
    </select>
    <select id="selectById" parameterType="int" resultType="com.pmp.hrsrc.entity.HintCard">
        select * from t_hintcard where uid =#{uid} order by id desc;
    </select>
</mapper>